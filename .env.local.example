# Copy this to apps/shell/.env.local for local development with Podman or Docker.
# Never commit .env.local files.

# Comma-separated list of S3 bucket names served by MinIO locally.
# Any bucket NOT in this list will be fetched from real AWS.
VITE_LOCAL_BUCKETS=hep-dev-modules,hep-dev-registry

# MinIO endpoint — routes through the Vite dev-server proxy to avoid CORS.
# The proxy is configured in auth-shell/vite.config.ts.
VITE_LOCAL_S3_ENDPOINT=http://localhost:9000

# DynamoDB Local endpoint — also proxied through Vite dev server.
VITE_LOCAL_DYNAMODB_ENDPOINT=http://localhost:5173/__local_ddb

# Fake credentials for local services (MinIO and DynamoDB Local accept any non-empty values)
VITE_LOCAL_AWS_ACCESS_KEY_ID=minioadmin
VITE_LOCAL_AWS_SECRET_ACCESS_KEY=minioadmin
VITE_LOCAL_AWS_REGION=us-east-1
